<section class="team-responsive-wrapper" id="the-team">
    <!-- Custom Name Follower (Desktop Only) -->
    <div class="name-follower" id="nameFollower">
        <div class="nf-inner">
            <span id="nf-name">NOM</span>
            <span id="nf-role">ROLE</span>
        </div>
    </div>

    <div class="team-layout" id="teamTarget">
        {
            teamMembers.map((member) => (
                <div
                    class="team-member"
                    data-name={member.name}
                    data-role={member.role}
                >
                    <img src={member.img} alt={member.name} />
                    <div class="mobile-info">
                        <h4>{member.name}</h4>
                        <p>{member.role}</p>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<script>
    gsap.registerPlugin(ScrollTrigger);

    const follower = document.getElementById("nameFollower");
    const nfName = document.getElementById("nf-name");
    const nfRole = document.getElementById("nf-role");
    const members = document.querySelectorAll(".team-member");

    // 1. ANIMATION: START WHEN ARRIVE
    gsap.to(".team-member", {
        scrollTrigger: {
            trigger: ".team-layout",
            start: "top 80%", // Starts when the top of the grid is 80% down the screen
        },
        y: 0,
        opacity: 1,
        stagger: 0.08, // One by one reveal
        duration: 1.2,
        ease: "power4.out",
    });

    // 2. MAGNETIC CURSOR (Desktop Only)
    if (window.innerWidth > 1024) {
        document.addEventListener("mousemove", (e) => {
            gsap.to(follower, {
                x: e.clientX - 80,
                y: e.clientY - 250,
                duration: 0.5,
                ease: "power2.out",
            });
        });

        members.forEach((member) => {
            member.addEventListener("mouseenter", () => {
                nfName.innerText = member.getAttribute("data-name");
                nfRole.innerText = member.getAttribute("data-role");
                gsap.to(follower, { opacity: 1, scale: 1, duration: 0.3 });
            });
            member.addEventListener("mouseleave", () => {
                gsap.to(follower, { opacity: 0, scale: 0, duration: 0.3 });
            });
        });
    }
</script>
