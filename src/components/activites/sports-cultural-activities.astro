---
import "../../../src/assets/style/sports-cultural-activities.css";
---

<section class="stagger-gallery-section" id="activitiesArea">
    <div class="stagger-container">
        
        <!-- Activity 1 -->
        <div class="stagger-item item-left">
            <div class="s-image-box">
                <img src="https://static.wixstatic.com/media/60ae4a_7f9419e4af544548b1295e9046a8b930~mv2.jpeg/v1/fill/w_858,h_540,fp_0.50_0.50,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/60ae4a_7f9419e4af544548b1295e9046a8b930~mv2.jpeg" alt="Activity 1">
            </div>
            <div class="s-content">
                <h3 class="s-title">REMISE EN FORME</h3>
                <div class="s-line"></div>
            </div>
        </div>

        <!-- Activity 2 -->
        <div class="stagger-item item-right">
            <div class="s-image-box">
                <img src="https://static.wixstatic.com/media/60ae4a_af530cf7eed84abe81beba7bac8e53ba~mv2.jpeg/v1/fill/w_858,h_540,fp_0.50_0.50,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/60ae4a_af530cf7eed84abe81beba7bac8e53ba~mv2.jpeg" alt="Activity 2">
            </div>
            <div class="s-content">
                <h3 class="s-title">ACTIVITÉS SPORTIVES DIVERSES</h3>
                <div class="s-line"></div>
            </div>
        </div>

        <!-- Activity 3 -->
        <div class="stagger-item item-left">
            <div class="s-image-box">
                <img src="https://static.wixstatic.com/media/60ae4a_6c16e89d1d9c442dabc5ea714e4943f9~mv2.jpeg/v1/fill/w_858,h_540,fp_0.50_0.50,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/60ae4a_6c16e89d1d9c442dabc5ea714e4943f9~mv2.jpeg" alt="Activity 3">
            </div>
            <div class="s-content">
                <h3 class="s-title">VISITES DE LIEUX CULTUREL</h3>
                <div class="s-line"></div>
            </div>
        </div>

        <!-- Activity 4 -->
        <div class="stagger-item item-right">
            <div class="s-image-box">
                <img src="https://static.wixstatic.com/media/60ae4a_9b30bf3ab2df4148afb9b2b696684b78~mv2.jpg/v1/fill/w_858,h_540,fp_0.58_0.29,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/60ae4a_9b30bf3ab2df4148afb9b2b696684b78~mv2.jpg" alt="Activity 4">
            </div>
            <div class="s-content">
                <h3 class="s-title">SOUTIEN SCOLAIRE</h3>
                <div class="s-line"></div>
            </div>
        </div>

    </div>
</section>

<script>
    // Robust check for GSAP
    window.addEventListener('load', () => {
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            // 1. Reveal each item as it enters the screen
            const items = document.querySelectorAll('.stagger-item');
            
            items.forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: {
                        trigger: item,
                        start: "top 85%",
                    },
                    y: 100,
                    opacity: 0,
                    duration: 1.2,
                    ease: "power4.out"
                });

                // Subtle parallax for the image inside
                const img = item.querySelector('img');
                gsap.to(img, {
                    scrollTrigger: {
                        trigger: item,
                        scrub: true
                    },
                    y: -30
                });
            });
        } else {
            console.error("GSAP not found. Check your CDN links.");
        }
    });
</script>